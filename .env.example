# Copy to `.env` at the repo root for Docker Compose or local runs.

USE_MOCK_LLM=false

# Primary (e.g. OpenRouter)
# LLM_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Automatic Groq fallback when primary rate-limits or errors (recommended)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
