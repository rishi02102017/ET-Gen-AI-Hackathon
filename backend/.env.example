# --- Primary (OpenRouter, OpenAI, or any OpenAI-compatible host) ---
# LLM_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_X_TITLE=FrameAtlas

# --- Automatic Groq fallback (recommended for demos / rate limits on free tiers) ---
# When primary fails (rate limit, 5xx, timeouts) or returns invalid JSON, the API retries on Groq
# with a configurable model (default in code: 70B for quality). Set GROQ_API_KEY in addition to LLM_API_KEY.
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
# LLM_PRIMARY_RATE_LIMIT_RETRIES=2
# LLM_FALLBACK_ENABLED=true
# LLM_FALLBACK_MAX_CHARS_PER_ARTICLE=8000

# --- Groq-only (no OpenRouter): use GROQ_API_KEY alone ---
# GROQ_API_KEY=gsk_...
# (Primary fields empty; Groq runs as the only provider.)

# --- Or Groq as primary via explicit base URL ---
# LLM_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

USE_MOCK_LLM=false
LLM_JSON_RESPONSE_FORMAT=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEBUG=false
